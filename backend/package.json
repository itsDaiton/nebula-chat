    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "openai": "^6.32.0",
    "openapi3-ts": "^4.5.0",
    "redis": "^5.11.0",
    "swagger-ui-express": "^5.0.1",
    "tiktoken": "^1.0.22",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@prisma/client": "^7.5.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/swagger-ui-express": "^4.1.8",
