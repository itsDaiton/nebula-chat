{
  "name": "nebula-chat-server",
  "version": "1.7.1",
  "packageManager": "pnpm@10.26.2",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "pnpm --filter @nebula-chat/db build && tsc && tsc-alias",
    "start": "node dist/src/server.js",
    "typecheck": "pnpm --filter @nebula-chat/db build && tsc --noEmit",
    "generate:openapi": "tsx src/scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/sensible": "^6.0.0",
    "@fastify/swagger": "^9.5.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@fastify/under-pressure": "^9.0.0",
    "@nebula-chat/db": "workspace:*",
    "drizzle-orm": "^0.44.0",
    "dotenv": "^17.4.0",
    "fastify": "^5.4.0",
    "fastify-plugin": "^5.0.0",
    "fastify-type-provider-zod": "^6.1.0",
    "openai": "^6.32.0",
    "pino": "^9.0.0",
    "redis": "^5.11.0",
    "tiktoken": "^1.0.22",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "pino-pretty": "^13.0.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  }
}
